# Copy to .env and fill in. .env is git-ignored.

# --- SMTP (Gmail shown; any STARTTLS+PLAIN provider works) -------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=you@gmail.com
SMTP_FROM_NAME=Footprint

# --- URLs --------------------------------------------------------------------
# Used in notification email links. Change when publishing behind a domain.
SITE_URL=http://localhost:8080

# Comma-separated origins allowed to call the API with credentials. Defaults
# cover the docker-compose nginx (8080) and the vite dev server (5173).
# ALLOWED_ORIGINS=https://notes.example.com

# --- Cookies -----------------------------------------------------------------
# When served over HTTPS, set this to true so the session cookie is marked
# Secure and never sent over plaintext HTTP.
COOKIE_SECURE=false

# --- Admin bootstrap (only used on very first boot when the DB is empty) -----
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me-before-going-anywhere-near-production
